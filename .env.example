# ════════════════════════════════════════════════════════════════════
#  VISIR API — Variables de entorno
#  Copia este archivo como .env y rellena los valores reales.
#  NUNCA subas tu .env real a un repositorio — solo este .env.example.
# ════════════════════════════════════════════════════════════════════

# ── Servicio ────────────────────────────────────────────────────────
# Leídas por app/core/config.py::Settings (pydantic-settings, case-insensitive)
APP_NAME="VISIR API"
APP_VERSION="0.2.0"
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000

# ── Supabase — base de datos, auth y storage ───────────────────────
# Leídas por app/core/config.py::Settings → app/core/database.py
# Obtener en: Supabase Dashboard → Settings → API
SUPABASE_URL=
SUPABASE_PUBLIC_KEY=
SUPABASE_SECRET_KEY=

# ── Extracción de CFDIs (OCR + Mistral) ────────────────────────────
# Leída por app/core/config.py::Settings y app/services/Extraccion/pipeline.py
# Obtener en: https://console.mistral.ai/
MISTRAL_API_KEY=

# ── LLM — generación de respuestas y enrutamiento (rag_service.py) ─
# Leídas por rag/config.py::load_config_from_env
#   Groq:     LLM_BASE_URL=https://api.groq.com/openai/v1
#   Ollama:   LLM_BASE_URL=http://localhost:11434/v1
#   OpenAI:   LLM_BASE_URL=https://api.openai.com/v1
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

# ── Embeddings — vectorización para el RAG ─────────────────────────
# Leídas por rag/config.py::load_config_from_env
#   Ollama (default):    EMBEDDING_BASE_URL=http://localhost:11434/v1  | EMBEDDING_API_KEY=ollama
#   Docker → Ollama host: EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
#   Linux + Docker:       EMBEDDING_BASE_URL=http://172.17.0.1:11434/v1
#   OpenAI:               EMBEDDING_BASE_URL=https://api.openai.com/v1 | EMBEDDING_API_KEY=sk-...
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=embeddinggemma:latest
EMBEDDING_TIMEOUT=30
EMBEDDING_MAX_RETRIES=3

# ── ChromaDB — base vectorial ───────────────────────────────────────
# Leídas por rag/config.py::load_config_from_env e app/routers/ingest_router.py
# CHROMA_COLLECTION:     normativa SAT, compartida y de solo lectura para todos
# CHROMA_ORG_COLLECTION: CFDIs y documentos subidos por cada organización,
#                        aislados entre sí por filtro de metadata id_organizacion
CHROMA_PATH=./chroma_db
CHROMA_COLLECTION=documentos_fiscales
CHROMA_ORG_COLLECTION=documentos_organizacion

# ── Evaluación del RAG (evaluaciones/run_eval.py) ──────────────────
# Solo necesarias para correr `uv run python -m evaluaciones.run_eval`.
# Pueden apuntar al mismo proveedor que LLM_* o a uno distinto usado como juez.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_JUDGE_MODEL=llama-3.3-70b-versatile

